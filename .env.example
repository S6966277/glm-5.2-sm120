# Copy to .env and adjust for your box. Defaults target 4x RTX PRO 6000 (SM120).

# Host path to the model weights (mounted read-only into the container).
MODEL=/mnt/llm_models/GLM-5.2-NVFP4-REAP-469B
SERVED_MODEL_NAME=glm-5.2
# Extra model ids clients can use (space-separated). The full name above always works too.
MODEL_ALIASES=GLM-5.2-NVFP4-REAP-469B GLM-5.2

# voipmonitor b12x image: provides GlmMoeDsaForCausalLM + Glm4MoeMTPModel +
# B12X_MLA_SPARSE (SM120-native sparse MLA) + NVFP4 (modelopt_fp4) MoE.
IMAGE=voipmonitor/vllm:black-benediction-b12xpr11-vllmbb6c5b7-b12xd90d89c-fi3395b41aa8d-dg324aced12c-cu132-20260608

# Reasoning model. Thinking is OFF by default so every request returns a direct
# answer (a reasoning model with a small max_tokens otherwise returns empty
# content while still 'thinking'). Set ENABLE_THINKING=1 for full chain-of-thought
# (then use a generous max_tokens, >=2000).
ENABLE_THINKING=1

NAME=glm52-vllm
PORT=8000

# Topology / context
TP_SIZE=4
DCP_SIZE=4                 # 250k ctx + 2.84x concurrency. For a FASTER <=128k endpoint
                           # use DCP_SIZE=1 + MAX_MODEL_LEN=131072 (~81 vs ~50 tok/s decode).
                           # DCP=1 OOMs above ~177k; DCP=4 shards MLA KV across the 4 GPUs.
MAX_MODEL_LEN=250000
MAX_NUM_SEQS=2             # concurrency (2.84x headroom at 250k)
MAX_NUM_BATCHED_TOKENS=8192
GPU_MEMORY_UTILIZATION=0.95

# MTP speculative decode
MTP=1
NUM_SPECULATIVE_TOKENS=3

# DSA per-layer indexer map (F=full, S=share/skip), 78 chars, derived from
# config.indexer_types. REQUIRED for long-context coherence. Override only if
# the model's indexer_types changes.
INDEX_TOPK_PATTERN=FFFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSS

# Where monitor.sh writes serve.log + peak.json (default ./logs next to the script).
# LOG_DIR=/var/log/glm52
